instrument: {
    type: keyboard
}
settings: {
    truesf: true,
    columns: 2,
    suppress-empty-chords: true,
    decapo: true
}

diagrams: {
sorted: true,
//suppress: [ C, G, D, A, E, F, Am, Em, Dm ]
}

pdf: {
papersize: a4,
fontconfig: {
serif: {
"":          Times-Roman,
bold:        Times-Bold,
italic:      Times-Italic,
bolditalic:  Times-BoldItalic
},
sans: {
"":          Helvetica,
bold:        Helvetica-Bold,
italic:      Helvetica-Oblique,
bolditalic:  Helvetica-BoldOblique
},
mono: {
"":          Courier,
bold:        Courier-Bold,
italic:      Courier-Oblique,
bolditalic:  Courier-BoldOblique
}
},

fonts: {
text:         "serif 12",
chord:        "sans bold 10",
title:        "serif bold 18",
subtitle:     "serif 14",
comment:      "sans italic 11",

tab: "mono 10",
toc: "serif 12"
},

spacing: {
lyrics: 1.4,
empty: 1.2
},

chorus: {
indent: 15,
bar: {
width: 1,
offset: 8,
color: grey60
},
recall: {
choruslike: true,
quote: true
}
},

diagrams: {
show: below
},

formats: {
title: {
footer: [ "%{artist}", "%{title}", "%{page}/%{pages}" ]
},
default: {
footer: [ "%{artist}", "%{title}", "%{page}/%{pages}" ]
}
}
}
