{
    "instrument": {
        "type": "vocals"
    },
    "settings": {
        "columns": 2,
        "lyrics-only": true
    },
    "pdf": {
        "papersize": "a4",
        "chorus": {
            "recall": {
                "choruslike": true,
                "quote": true
            }
        },
        "diagrams": {
            "show": "none"
        },
        "kbdiagrams": {
            "show": "none"
        },
        "formats": {
            "title": {
                "subtitle": [
                    "",
                    "%{artist} · Helistik: %{_key} · Tempo: %{tempo} BPM",
                    ""
                ]
            },
            "default": {
                "footer": false
            }
        }
    }
}
